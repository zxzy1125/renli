# Main site
# Caddy automatically obtains & renews Let's Encrypt SSL certificates
# When DOMAIN=localhost, Caddy serves HTTP only (no SSL)
{$DOMAIN} {
	# Gzip compression
	encode gzip

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}

	# Cache static assets (Vite uses content hashes in filenames)
	@assets {
		path /assets/*
	}
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Handle API requests first（与下面的前端 handle 互斥）
	handle /api/* {
		reverse_proxy backend:3001 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# 前端静态文件 + SPA 路由兜底（handle 块与 /api/* 互斥，不会拦截 API 请求）
	handle {
		root * /srv
		# 非文件请求回退到 index.html（Vue/React Router history 模式必需）
		try_files {path} /index.html
		file_server
	}
}
