# ============================================================
#  代招助手 服务端环境变量
#  复制此文件为 .env 并修改对应值
#  cp .env.example .env
# ============================================================

# 域名（生产环境部署时需要，用于自动 SSL）
DOMAIN=your-domain.com

# JWT 密钥（必填！生产环境务必更换为随机强密钥）
# 生成方法：openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-key

# 服务端口
PORT=3001

# CORS 允许的来源（逗号分隔，如：https://app.example.com,https://admin.example.com）
# 留空则默认允许 localhost:5173 和 localhost:3000
CORS_ORIGINS=

# 运行环境（development / production）
NODE_ENV=development
