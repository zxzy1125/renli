# ============================================================
#  Docker Compose 环境变量配置
#  使用方法：复制为 .env 并修改对应值
#  cp .env.example .env && nano .env
# ============================================================

# 站点域名（Caddy 会自动申请 HTTPS 证书）
DOMAIN=renli.xiaoqingai.top

# JWT 密钥（建议改为随机长字符串）
JWT_SECRET=trae-recruit-secret-key-2026

# 项目根目录（服务器上 git clone 的位置）
# 默认 /opt/recruit-tool，如果部署在其他路径请修改
PROJECT_ROOT=/opt/recruit-tool
