# ============================================================
#  Deployment Configuration
#  Copy this file to .env and modify values
#  cp .env.example .env
# ============================================================

# Your domain name (required for automatic SSL)
# Use a real domain pointing to your server's IP for HTTPS
# Use "localhost" for local testing (HTTP only, no SSL)
DOMAIN=your-domain.com

# JWT secret for authentication tokens
# IMPORTANT: Change this to a long random string in production!
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-key
